# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Optional DB pool/query safety tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=8000
DB_QUERY_TIMEOUT_MS=10000
DB_IDLE_IN_TX_TIMEOUT_MS=8000

# Server
PORT=3000
NODE_ENV=development

# Session cookie name
SESSION_COOKIE_NAME=csatlas_session
# Session cookie policy: strict | lax | none
SESSION_COOKIE_SAME_SITE=lax
# Session cookie secure mode: auto | true | false
SESSION_COOKIE_SECURE=auto
# Optional: trusted browser origins allowed to call API cross-origin (comma-separated, include https:// and no trailing slash)
# Example: ALLOWED_ORIGINS=https://eddyarriaga00.github.io,https://www.cscourseatlas.com
# If ALLOWED_ORIGINS is set for public cross-origin auth, set SESSION_COOKIE_SAME_SITE=none and SESSION_COOKIE_SECURE=true.
ALLOWED_ORIGINS=
# Max number of simultaneous active sessions per user
MAX_ACTIVE_SESSIONS_PER_USER=6
# Trust proxy setting: false | true | <number of trusted hops>
TRUST_PROXY=0

# Security tuning (optional)
GLOBAL_API_WINDOW_MS=60000
GLOBAL_API_MAX_REQUESTS=240
AUTH_WINDOW_MS=900000
AUTH_MAX_REQUESTS=12
AUTH_IDENTITY_WINDOW_MS=900000
AUTH_IDENTITY_MAX_FAILURES=8
AUTH_IDENTITY_BLOCK_MS=1800000
SUPPORT_WINDOW_MS=900000
SUPPORT_MAX_REQUESTS=20
SUPPORT_MAX_MESSAGE_LENGTH=5000
SUPPORT_MAX_FIELD_LENGTH=160
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
JSON_MAX_DEPTH=12
JSON_MAX_KEYS=1500
JSON_MAX_ARRAY_LENGTH=250
JSON_MAX_STRING_LENGTH=10000
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_HEADERS_TIMEOUT_MS=35000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
SECURITY_CLEANUP_INTERVAL_MS=900000
SECURITY_EVENT_RETENTION_HOURS=48
REQUIRE_JSON_MUTATIONS=true
ENFORCE_FETCH_METADATA=true
# Optional comma-separated allowlist for Host header values (e.g. localhost:3000,example.com)
ALLOWED_HOSTS=

# Email verification PIN flow (Account secure email change)
EMAIL_PIN_EXPIRY_MINUTES=10
EMAIL_PIN_MAX_ATTEMPTS=5
# Use "log" for local/dev (prints PIN in server logs), "disabled" for no delivery.
EMAIL_PIN_DELIVERY_MODE=log
# Optional additional secret used when hashing PIN codes.
EMAIL_PIN_PEPPER=
# Returns devPin in API response when true (auto-true outside production).
EMAIL_PIN_DEBUG_RESPONSE=true

# Optional API base override used by frontend runtime config
# APP_CONFIG_API_BASE_URL=http://localhost:3000
